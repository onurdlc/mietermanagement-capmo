generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  name           String?
  role           String
  organizationId String?
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  comments       Comment[]
  auditLogs      AuditLog[]

  @@index([organizationId])
  @@index([role])
}

model Organization {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  plan            String     @default("STARTER")
  seats           Int        @default(5)
  isActive        Boolean    @default(true)
  primaryColor    String     @default("#08b7ca")
  secondaryColor  String     @default("#00d994")
  logoUrl         String?
  customDomain    String?
  billingEmail    String?
  capmoApiBaseUrl String?
  capmoProjectId  String?
  capmoApiKeyRef  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  users           User[]
  properties      Property[]
  tickets         Ticket[]
  auditLogs       AuditLog[]
  conversations   AiConversation[]
  imageAnalyses   ImageAnalysis[]

  @@index([slug])
  @@index([isActive])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenants        Tenant[]
  tickets        Ticket[]

  @@index([organizationId])
}

model Tenant {
  id            String           @id @default(cuid())
  propertyId    String
  tenantNumber  String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  mobile        String?
  unit          String?
  floor         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  property      Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tickets       Ticket[]
  conversations AiConversation[]

  @@index([tenantNumber, lastName])
  @@index([propertyId])
  @@unique([propertyId, tenantNumber])
}

model Ticket {
  id                 String          @id @default(cuid())
  organizationId     String
  propertyId         String
  tenantId           String
  capmoTicketId      String?
  title              String
  description        String
  category           String?
  type               String?
  location           String?
  status             String          @default("Open")
  priority           String          @default("NORMAL")
  slaDueAt           DateTime?
  dueDate            DateTime?
  company            String?
  responsiblePersons String?
  capmoSyncStatus    String?         @default("PENDING")
  capmoLastSyncedAt  DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attachments        Attachment[]
  comments           Comment[]
  statusHistory      StatusHistory[]
  syncLogs           CapmoSyncLog[]
  conversations      AiConversation[]
  imageAnalyses      ImageAnalysis[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([capmoTicketId])
  @@index([status])
  @@index([priority])
}

model Attachment {
  id                String          @id @default(cuid())
  ticketId          String
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int
  capmoAttachmentId String?
  createdAt         DateTime        @default(now())
  ticket            Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  imageAnalyses     ImageAnalysis[]

  @@index([ticketId])
}

model Comment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([authorId])
}

model StatusHistory {
  id        String   @id @default(cuid())
  ticketId  String
  oldStatus String?
  newStatus String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model CapmoSyncLog {
  id              String   @id @default(cuid())
  ticketId        String?
  direction       String
  status          String
  requestPayload  String?
  responsePayload String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  ticket          Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([status])
  @@index([direction])
}

model AiConversation {
  id             String          @id @default(cuid())
  organizationId String
  tenantId       String?
  ticketId       String?
  channel        String          @default("CHAT")
  language       String          @default("de")
  status         String          @default("COLLECTING")
  messages       Json
  extractedData  Json?
  missingFields  Json?
  transcriptText String?
  voiceFileUrl   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  ticket         Ticket?         @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  imageAnalyses  ImageAnalysis[]

  @@index([organizationId])
  @@index([tenantId])
  @@index([ticketId])
  @@index([status])
}

model ImageAnalysis {
  id                String          @id @default(cuid())
  organizationId    String
  conversationId    String?
  ticketId          String?
  attachmentId      String?
  imageUrl          String
  fileName          String?
  model             String          @default("mock-vision")
  status            String          @default("COMPLETED")
  detectedDamage    String?
  detectedTrade     String?
  detectedRoom      String?
  severity          String          @default("NORMAL")
  warrantyLikelihood String         @default("UNKNOWN")
  confidence        Float           @default(0.5)
  summary           String?
  recommendations   Json?
  extractedData     Json?
  followUpQuestions Json?
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation      AiConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  ticket            Ticket?         @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  attachment        Attachment?     @relation(fields: [attachmentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([ticketId])
  @@index([attachmentId])
  @@index([detectedDamage])
  @@index([detectedTrade])
  @@index([severity])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
  @@index([action])
}
