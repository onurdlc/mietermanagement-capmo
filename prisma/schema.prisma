generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  role           String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Tenant {
  id           String   @id @default(cuid())
  propertyId   String
  tenantNumber String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  mobile       String?
  unit         String?
  floor        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Ticket {
  id                 String   @id @default(cuid())
  organizationId     String
  propertyId         String
  tenantId           String
  capmoTicketId      String?
  title              String
  description        String
  category           String?
  type               String?
  location           String?
  status             String
  dueDate            DateTime?
  company            String?
  responsiblePersons String?
  capmoSyncStatus    String?
  capmoLastSyncedAt  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Attachment {
  id                String   @id @default(cuid())
  ticketId          String
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int
  capmoAttachmentId String?
  createdAt         DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  source    String
  createdAt DateTime @default(now())
}

model StatusHistory {
  id        String   @id @default(cuid())
  ticketId  String
  oldStatus String?
  newStatus String
  source    String
  createdAt DateTime @default(now())
}

model CapmoSyncLog {
  id              String   @id @default(cuid())
  ticketId        String?
  direction       String
  status          String
  requestPayload  String?
  responsePayload String?
  errorMessage    String?
  createdAt       DateTime @default(now())
}
