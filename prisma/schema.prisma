generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String?
  name           String?
  role           String
  organizationId String?
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  comments       Comment[]

  @@index([organizationId])
  @@index([role])
}

model Organization {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  plan            String     @default("STARTER")
  seats           Int        @default(5)
  isActive        Boolean    @default(true)
  primaryColor    String     @default("#08b7ca")
  secondaryColor  String     @default("#00d994")
  logoUrl         String?
  customDomain    String?
  billingEmail    String?
  capmoApiBaseUrl String?
  capmoProjectId  String?
  capmoApiKeyRef  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  users           User[]
  properties      Property[]
  tickets         Ticket[]

  @@index([slug])
  @@index([isActive])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenants        Tenant[]
  tickets        Ticket[]

  @@index([organizationId])
}

model Tenant {
  id           String   @id @default(cuid())
  propertyId   String
  tenantNumber String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  mobile       String?
  unit         String?
  floor        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@index([tenantNumber, lastName])
  @@index([propertyId])
  @@unique([propertyId, tenantNumber])
}

model Ticket {
  id                 String          @id @default(cuid())
  organizationId     String
  propertyId         String
  tenantId           String
  capmoTicketId      String?
  title              String
  description        String
  category           String?
  type               String?
  location           String?
  status             String          @default("Open")
  priority           String          @default("NORMAL")
  dueDate            DateTime?
  company            String?
  responsiblePersons String?
  capmoSyncStatus    String?         @default("PENDING")
  capmoLastSyncedAt  DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attachments        Attachment[]
  comments           Comment[]
  statusHistory      StatusHistory[]
  syncLogs           CapmoSyncLog[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([capmoTicketId])
  @@index([status])
}

model Attachment {
  id                String   @id @default(cuid())
  ticketId          String
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int
  capmoAttachmentId String?
  createdAt         DateTime @default(now())
  ticket            Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Comment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([authorId])
}

model StatusHistory {
  id        String   @id @default(cuid())
  ticketId  String
  oldStatus String?
  newStatus String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model CapmoSyncLog {
  id              String   @id @default(cuid())
  ticketId        String?
  direction       String
  status          String
  requestPayload  String?
  responsePayload String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  ticket          Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([status])
  @@index([direction])
}
