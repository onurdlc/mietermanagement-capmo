generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String?
  role           String
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  comments       Comment[]
}

model Organization {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
  tickets    Ticket[]
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenants        Tenant[]
  tickets        Ticket[]

  @@index([organizationId])
}

model Tenant {
  id           String   @id @default(cuid())
  propertyId   String
  tenantNumber String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  mobile       String?
  unit         String?
  floor        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@index([tenantNumber, lastName])
  @@index([propertyId])
}

model Ticket {
  id                 String          @id @default(cuid())
  organizationId     String
  propertyId         String
  tenantId           String
  capmoTicketId      String?
  title              String
  description        String
  category           String?
  type               String?
  location           String?
  status             String          @default("Open")
  dueDate            DateTime?
  company            String?
  responsiblePersons String?
  capmoSyncStatus    String?         @default("PENDING")
  capmoLastSyncedAt  DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attachments        Attachment[]
  comments           Comment[]
  statusHistory      StatusHistory[]
  syncLogs           CapmoSyncLog[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([capmoTicketId])
  @@index([status])
}

model Attachment {
  id                String   @id @default(cuid())
  ticketId          String
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int
  capmoAttachmentId String?
  createdAt         DateTime @default(now())
  ticket            Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Comment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([authorId])
}

model StatusHistory {
  id        String   @id @default(cuid())
  ticketId  String
  oldStatus String?
  newStatus String
  source    String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model CapmoSyncLog {
  id              String   @id @default(cuid())
  ticketId        String?
  direction       String
  status          String
  requestPayload  String?
  responsePayload String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  ticket          Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([status])
  @@index([direction])
}
